[Unit]
Wants=image-bootstrap@%N.service image-build@%N.timer
After=image-bootstrap@%N.service home.service

[Container]
Image=localhost/nodered
Environment=TZ=Europe/Berlin
#PublishPort=127.0.0.1:1880:1880
Network=host
#User=110
#Group=0
Volume=/var/mnt/persist/home/nodered:/data
AutoUpdate=local
HealthCmd=curl --fail --silent --show-error localhost:1880 || exit 1
HealthOnFailure=kill
HealthInterval=5m

[Service]
Restart=on-failure
Slice=prod-tier0.slice

[Install]
WantedBy=prod.target
