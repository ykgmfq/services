[Unit]
Wants=image-bootstrap@%N.service image-build@%N.timer
After=image-bootstrap@%N.service

[Container]
Image=localhost/mosquitto
PublishPort=127.0.0.1:1883:1883
PublishPort=127.0.0.1:1884:1884
AutoUpdate=local
Secret=mosquitto_passwords,uid=1883,gid=1883,mode=0400
HealthCmd=mosquitto_sub --id healthcheck --topic '$SYS/broker/version' -C 1
HealthOnFailure=kill

[Service]
Restart=on-failure
Slice=prod-tier0.slice

[Install]
WantedBy=prod.target
